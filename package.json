{
  "name": "spotify-playlist-ts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "",
  "scripts": {
    "start": "tsx src/index.ts",
    "build:app": "esbuild electron/main.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist-electron/main.cjs && esbuild electron/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist-electron/preload.cjs",
    "app": "npm run build:app && electron dist-electron/main.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "youtube-dl-exec": "^3.1.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "^43.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "allowScripts": {
    "ffmpeg-static@5.3.0": true,
    "youtube-dl-exec@3.1.9": true,
    "esbuild@0.28.1": true
  }
}
